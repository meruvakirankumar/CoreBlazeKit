    <!-- ══ Theming ═══════════════════════════════════════════════════ -->
    <section class="gs-section">
        <h2 class="gs-section__title">Theming &amp; dark mode</h2>
        <p class="gs-section__desc">
            CoreBlaze uses CSS custom properties throughout. Override any variable at the <code>:root</code> level to apply a global brand colour,
            or add the <code>cb-theme-dark</code> class to any ancestor element to switch that subtree to dark mode.
        </p>
        <div class="gs-two-col">
            <div class="gs-code-block">
                <div class="gs-code-block__filename">Custom brand colour</div>
                <pre><code>:root {
    --cb-primary:      #0ea5e9; /* sky blue */
    --cb-primary-dark: #0284c7;
}</code></pre>
            </div>
            <div class="gs-code-block">
                <div class="gs-code-block__filename">Dark mode toggle (Blazor)</div>
                <pre><code>&lt;div class="@@(_dark ? "cb-theme-dark" : null)"&gt;
    &lt;!-- all CoreBlaze components inside use dark palette --&gt;
    &lt;DataGrid ... /&gt;
&lt;/div&gt;

@@code {
    bool _dark = false;
}</code></pre>
            </div>
        </div>

        <div class="gs-token-table">
            <div class="gs-token-table__title">Key CSS variables</div>
            <table>
                <thead>
                    <tr><th>Variable</th><th>Default (light)</th><th>Description</th></tr>
                </thead>
                <tbody>
                    <tr><td><code>--cb-primary</code></td><td><span class="gs-swatch" style="background:#4f46e5"></span>#4f46e5</td><td>Brand / accent colour</td></tr>
                    <tr><td><code>--cb-surface</code></td><td><span class="gs-swatch" style="background:#ffffff;border:1px solid #e5e7eb"></span>#ffffff</td><td>Component background</td></tr>
                    <tr><td><code>--cb-border</code></td><td><span class="gs-swatch" style="background:#e5e7eb"></span>#e5e7eb</td><td>Borders and dividers</td></tr>
                    <tr><td><code>--cb-text</code></td><td><span class="gs-swatch" style="background:#111827"></span>#111827</td><td>Primary text colour</td></tr>
                    <tr><td><code>--cb-radius</code></td><td>0.5rem</td><td>Component border radius</td></tr>
                    <tr><td><code>--cb-font</code></td><td>system-ui, sans-serif</td><td>Component font family</td></tr>
                </tbody>
            </table>
        </div>
    </section>

