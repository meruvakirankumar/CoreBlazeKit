<script>
function gsTab(containerId, tabId) {
    const container = document.getElementById(containerId);
    if (!container) return;
    container.querySelectorAll('.gs-tab').forEach(t => t.classList.remove('gs-tab--active'));
    container.querySelectorAll('.gs-tab-panel').forEach(p => p.classList.remove('gs-tab-panel--active'));
    const activeTab = [...container.querySelectorAll('.gs-tab')].find(t => t.getAttribute('onclick')?.includes("'" + tabId + "'"));
    if (activeTab) activeTab.classList.add('gs-tab--active');
    const activePanel = container.querySelector('[data-tab="' + tabId + '"]');
    if (activePanel) activePanel.classList.add('gs-tab-panel--active');
}
function gsCopy(btn, text) {
    navigator.clipboard.writeText(text).then(() => {
        const orig = btn.textContent;
        btn.textContent = '✓ Copied';
        btn.classList.add('gs-copy-btn--copied');
        setTimeout(() => { btn.textContent = orig; btn.classList.remove('gs-copy-btn--copied'); }, 1800);
    });
}
</script>

