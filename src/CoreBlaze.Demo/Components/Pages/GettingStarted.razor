@page "/docs/getting-started"

<PageTitle>Getting Started · CoreBlaze</PageTitle>

<div class="gs-page">

    <!-- ══ Hero ══════════════════════════════════════════════════════ -->
    <div class="gs-hero">
        <div class="gs-hero__badge">v0.1.0 · MIT · .NET 8+</div>
        <h1 class="gs-hero__title">Getting Started with CoreBlaze</h1>
        <p class="gs-hero__lead">
            A lightweight Razor Class Library of production-ready Blazor components —
            inputs, grids, spinners, tabs, toasts, and more — packaged as a NuGet library
            and ready to drop into any Blazor Server or Blazor Web App project.
        </p>
        <div class="gs-hero__links">
            <a class="gs-btn gs-btn--primary" href="https://github.com/meruvakirankumar/CoreBlazeKit" target="_blank">
                <span>GitHub</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.4.6.1.82-.26.82-.58v-2.16c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02 0 2.04.13 3 .4 2.28-1.55 3.29-1.23 3.29-1.23.66 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.82 1.1.82 2.22v3.29c0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12C24 5.37 18.63 0 12 0z"/></svg>
            </a>
            <a class="gs-btn gs-btn--outline" href="inputs">Browse components →</a>
        </div>
    </div>

    <!-- ══ Step 1: Install ═══════════════════════════════════════════ -->
    <section class="gs-section">
        <div class="gs-step-label">Step 1</div>
        <h2 class="gs-section__title">Install the NuGet package</h2>
        <p class="gs-section__desc">Add CoreBlaze.Components to your Blazor project via the .NET CLI, Package Manager, or your <code>.csproj</code> file.</p>

        <div class="gs-tabs" id="install-tabs">
            <div class="gs-tabs__bar">
                <button class="gs-tab gs-tab--active" onclick="gsTab('install-tabs','cli')">CLI</button>
                <button class="gs-tab" onclick="gsTab('install-tabs','pm')">Package Manager</button>
                <button class="gs-tab" onclick="gsTab('install-tabs','csproj')">csproj</button>
            </div>
            <div class="gs-tab-panel gs-tab-panel--active" data-tab="cli">
                <div class="gs-code-block">
                    <pre><code>dotnet add package CoreBlaze.Components</code></pre>
                    <button class="gs-copy-btn" onclick="gsCopy(this, 'dotnet add package CoreBlaze.Components')">Copy</button>
                </div>
            </div>
            <div class="gs-tab-panel" data-tab="pm">
                <div class="gs-code-block">
                    <pre><code>Install-Package CoreBlaze.Components</code></pre>
                    <button class="gs-copy-btn" onclick="gsCopy(this, 'Install-Package CoreBlaze.Components')">Copy</button>
                </div>
            </div>
            <div class="gs-tab-panel" data-tab="csproj">
                <div class="gs-code-block">
                    <pre><code>&lt;PackageReference Include="CoreBlaze.Components" Version="0.1.0" /&gt;</code></pre>
                    <button class="gs-copy-btn" onclick="gsCopy(this, '&lt;PackageReference Include=&quot;CoreBlaze.Components&quot; Version=&quot;0.1.0&quot; /&gt;')">Copy</button>
                </div>
            </div>
        </div>
    </section>

    <!-- ══ Step 2: Add CSS & JS ═══════════════════════════════════════ -->
    <section class="gs-section">
        <div class="gs-step-label">Step 2</div>
        <h2 class="gs-section__title">Add CSS &amp; JS to <code>App.razor</code></h2>
        <p class="gs-section__desc">
            The RCL ships one stylesheet and one small JS helper (used for file downloads and clipboard copy).
            Reference them in <code>App.razor</code> or your <code>&lt;head&gt;</code> layout.
        </p>
        <div class="gs-code-block">
            <div class="gs-code-block__filename">App.razor</div>
            <pre><code>&lt;head&gt;
    ...
    &lt;!-- CoreBlaze styles --&gt;
    &lt;link rel="stylesheet"
          href="_content/CoreBlaze.Components/coreblaze.css" /&gt;
&lt;/head&gt;
&lt;body&gt;
    &lt;Routes /&gt;
    &lt;!-- CoreBlaze JS helpers (clipboard, file download) --&gt;
    &lt;script src="_content/CoreBlaze.Components/coreblaze.js"&gt;&lt;/script&gt;
&lt;/body&gt;</code></pre>
        </div>
    </section>

    <!-- ══ Step 3: _Imports.razor ════════════════════════════════════ -->
    <section class="gs-section">
        <div class="gs-step-label">Step 3</div>
        <h2 class="gs-section__title">Add namespaces to <code>_Imports.razor</code></h2>
        <p class="gs-section__desc">
            Add the CoreBlaze namespaces so you can use components without per-page <code>@@using</code> directives.
        </p>
        <div class="gs-code-block">
            <div class="gs-code-block__filename">_Imports.razor</div>
            <pre><code>@@using CoreBlaze.Components
@@using CoreBlaze.Components.Grid
@@using CoreBlaze.Components.Inputs
@@using CoreBlaze.Components.Shared
@@using CoreBlaze.Components.Services</code></pre>
        </div>
    </section>

    <!-- ══ Step 4: Optional services ════════════════════════════════ -->
    <section class="gs-section">
        <div class="gs-step-label">Step 4 (optional)</div>
        <h2 class="gs-section__title">Register optional services</h2>
        <p class="gs-section__desc">
            Register <code>ThemeService</code> if you want programmatic dark / light mode switching from C# code.
            The service is not required if you toggle dark mode by adding <code>cb-theme-dark</code> to a DOM element yourself.
        </p>
        <div class="gs-code-block">
            <div class="gs-code-block__filename">Program.cs</div>
            <pre><code>builder.Services.AddScoped&lt;CoreBlaze.Components.Services.ThemeService&gt;();</code></pre>
        </div>
    </section>

