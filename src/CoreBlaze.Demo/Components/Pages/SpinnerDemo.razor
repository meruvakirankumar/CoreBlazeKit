@page "/layout/spinner"

<PageTitle>Spinner · CoreBlaze</PageTitle>

<div class="page-header">
    <h1>Spinner</h1>
    <p class="text-muted">
        Four animation variants — Ring, Pulse, Wave, Gradient — with custom colours,
        a centre image / icon / markup slot, and a <code>LoadingOverlay</code> wrapper.
    </p>
</div>

<!-- ══════════════════ Interactive Playground ══════════════════ -->
<div class="sp-playground demo-section">

    <!-- Left: controls panel -->
    <div class="sp-controls">

        <!-- Variant -->
        <div class="sp-group">
            <div class="sp-group__label">Animation variant</div>
            <div class="sp-chip-row">
                @foreach (var v in Enum.GetValues<SpinnerVariant>())
                {
                    <button type="button"
                            class="sp-chip @(_variant == v ? "sp-chip--active" : null)"
                            @onclick="() => _variant = v">
                        @v
                    </button>
                }
            </div>
        </div>

        <!-- Size -->
        <div class="sp-group">
            <div class="sp-group__label">Size</div>
            <div class="sp-chip-row">
                @foreach (var s in Enum.GetValues<SpinnerSize>())
                {
                    <button type="button"
                            class="sp-chip @(_size == s ? "sp-chip--active" : null)"
                            @onclick="() => _size = s">
                        @s
                    </button>
                }
            </div>
        </div>

        <!-- Ring count -->
        <div class="sp-group">
            <div class="sp-group__label">
                Ring count
                <span class="sp-group__badge">@(ResolvedRingCount) ring@(ResolvedRingCount != 1 ? "s" : "")</span>
            </div>
            <div class="sp-slider-row">
                <span class="sp-slider-tick">0</span>
                <input type="range" class="sp-slider" min="0" max="6" step="1"
                       value="@_ringCount"
                       @oninput="e => _ringCount = int.Parse(e.Value!.ToString()!)" />
                <span class="sp-slider-tick">6</span>
            </div>
            <div class="sp-slider-hint">0 = auto (1 ring for Ring/Gradient, 3 for Pulse/Wave)</div>
        </div>

        <!-- Centre content -->
        <div class="sp-group">
            <div class="sp-group__label">Centre content</div>
            <div class="sp-field-row">
                <div class="sp-field">
                    <label class="sp-field__label">Icon / emoji</label>
                    <input type="text" class="sp-input"
                           placeholder="e.g. 🔒  ✓  ★"
                           value="@_centerIcon"
                           @oninput="e => _centerIcon = e.Value?.ToString() ?? string.Empty" />
                </div>
                <div class="sp-field">
                    <label class="sp-field__label">Label text</label>
                    <input type="text" class="sp-input"
                           placeholder="e.g. Loading…"
                           value="@_label"
                           @oninput="e => _label = e.Value?.ToString() ?? string.Empty" />
                </div>
            </div>
        </div>

        <!-- Colours — dynamic swatches -->
        <div class="sp-group">
            <div class="sp-group__label">
                Colours
                <span class="sp-group__badge">@_colors.Count</span>
            </div>
            <div class="sp-colors">
                @for (int i = 0; i < _colors.Count; i++)
                {
                    var idx = i;
                    var hex = _colors[idx];
                    <div class="sp-color-swatch">
                        <input type="color" class="sp-color-input"
                               value="@hex"
                               title="Colour @(idx + 1)"
                               @oninput="e => UpdateColor(idx, e.Value?.ToString() ?? hex)" />
                        <span class="sp-color-label">
                            <span class="sp-color-dot" style="background:@hex"></span>
                            <code>@hex</code>
                        </span>
                        @if (_colors.Count > 1)
                        {
                            <button class="sp-clear-btn" title="Remove colour @(idx + 1)" @onclick="() => RemoveColor(idx)">×</button>
                        }
                    </div>
                }
            </div>
            <div class="sp-colors-footer">
                <button type="button" class="sp-add-color-btn" @onclick="AddColor" title="Add another colour">
                    + Add colour
                </button>
                <label class="sp-toggle-row">
                    <input type="checkbox" @bind="_useColors" />
                    <span class="sp-toggle-text">Apply custom colours</span>
                    <span class="sp-toggle-hint">Uncheck to use the default indigo theme</span>
                </label>
            </div>
        </div>

    </div>

    <!-- Right: live preview -->
    <div class="sp-preview-panel">
        <div class="sp-preview-label">Live preview</div>
        <div class="sp-preview-stage">
            <Spinner Size="_size"
                     Variant="_variant"
                     RingCount="_ringCount"
                     Colors="_useColors ? ResolvedColors : null"
                     Label="@(string.IsNullOrEmpty(_label) ? null : _label)"
                     CenterIcon="@(string.IsNullOrEmpty(_centerIcon) ? null : _centerIcon)"
                     CenterImage="@(string.IsNullOrEmpty(_centerImage) ? null : _centerImage)" />
        </div>
        <div class="sp-preview-meta">
            <span>@_variant</span>
            <span>·</span>
            <span>@_size</span>
            @if (_useColors && ResolvedColors is { Count: > 0 })
            {
                <span>·</span>
                <span>@ResolvedColors!.Count colour@(ResolvedColors.Count != 1 ? "s" : "")</span>
            }
            @if (!string.IsNullOrEmpty(_centerIcon))
            {
                <span>·</span>
                <span>icon: @_centerIcon</span>
            }
        </div>
    </div>
</div>

<!-- ══════════════════ Sizes showcase ══════════════════ -->
<div class="demo-section">
    <h3>Size scale</h3>
    <p class="demo-section__hint">Six presets from XSmall (8 px) to XXLarge (96 px).</p>
    <div class="sp-size-row">
        @foreach (var s in Enum.GetValues<SpinnerSize>())
        {
            <div class="sp-size-card">
                <Spinner Size="@s" />
                <code class="sp-size-label">@s</code>
            </div>
        }
    </div>
</div>

<!-- ══════════════════ Gallery ══════════════════ -->
<div class="demo-section">
    <h3>Presets gallery</h3>
    <p class="demo-section__hint">Ready-to-use configurations spanning every variant — click any card to copy the code.</p>

    <div class="spinner-gallery">

        @foreach (var preset in _galleryPresets)
        {
            <div class="spinner-gallery__card" @onclick="() => CopyPresetCode(preset)" title="Click to copy code">
                <div class="spinner-gallery__preview">
                    @preset.Render
                </div>
                <div class="spinner-gallery__info">
                    <span class="spinner-gallery__name">@preset.Name</span>
                    <div class="spinner-gallery__tags">
                        <span class="sg-tag sg-tag--variant">@preset.Variant</span>
                        <span class="sg-tag sg-tag--size">@preset.Size</span>
                        @if (preset.RingCount > 0)
                        {
                            <span class="sg-tag">@preset.RingCount rings</span>
                        }
                        @if (preset.Colors.Length > 0)
                        {
                            <span class="sg-tag sg-tag--colors">
                                @foreach (var c in preset.Colors)
                                {
                                    <span class="sg-color-dot" style="background:@c"></span>
                                }
                                @preset.Colors.Length colour@(preset.Colors.Length != 1 ? "s" : "")
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(preset.CenterIcon))
                        {
                            <span class="sg-tag">@preset.CenterIcon</span>
                        }
                    </div>
                    <div class="spinner-gallery__code">
                        <pre><code>@preset.Code</code></pre>
                        <button class="sg-copy-btn @(_copiedPreset == preset.Name ? "sg-copy-btn--copied" : null)"
                                @onclick:stopPropagation="true"
                                @onclick="() => CopyPresetCode(preset)">
                            @(_copiedPreset == preset.Name ? "✓ Copied" : "Copy")
                        </button>
                    </div>
                </div>
            </div>
        }

    </div>
</div>

<!-- ══════════════════ LoadingOverlay + Sidebar ══════════════════ -->
<div class="row g-3">
    <div class="col-lg-7">
        <div class="demo-section">
            <h3>LoadingOverlay</h3>
            <p class="demo-section__hint">Masks any child block with a blurred curtain while an async operation runs.</p>
            <LoadingOverlay IsLoading="_isLoading" LoadingText="Please wait…" SpinnerSize="SpinnerSize.Large">
                <div class="sp-overlay-content">
                    <p><strong>Protected content area</strong></p>
                    <p class="text-muted mb-0">Cards, forms, tables — any children can live here. They are masked while loading.</p>
                </div>
            </LoadingOverlay>
            <div class="mt-3">
                <button class="btn btn-sm btn-primary" @onclick="SimulateLoadAsync" disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <Spinner Size="SpinnerSize.Small" />
                        <span class="ms-2">Simulating…</span>
                    }
                    else { <span>Simulate 2 s load</span> }
                </button>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="demo-section">
            <h3>Usage</h3>
            <CodeSample Code="@_code" />
        </div>
    </div>
</div>

<style>
/* ── Playground layout ──────────────────────────────────────── */
.sp-playground {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.5rem;
    align-items: start;
}

@@media (max-width: 860px) {
    .sp-playground { grid-template-columns: 1fr; }
    .sp-preview-panel { order: -1; }
}

/* ── Controls ───────────────────────────────────────────────── */
.sp-controls {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
}

.sp-group { display: flex; flex-direction: column; gap: 0.45rem; }

.sp-group__label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--app-text-mute);
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.sp-group__badge {
    background: color-mix(in srgb, var(--app-brand) 12%, transparent);
    color: var(--app-brand);
    border-radius: 999px;
    padding: 0.1rem 0.5rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0;
}

/* Chip row */
.sp-chip-row { display: flex; gap: 0.4rem; flex-wrap: wrap; }

.sp-chip {
    padding: 0.3rem 0.85rem;
    font-size: 0.85rem;
    font-weight: 500;
    background: var(--app-bg-elev);
    border: 1.5px solid var(--app-border);
    border-radius: 999px;
    cursor: pointer;
    color: var(--app-text-mute);
    transition: all 120ms ease;
    font-family: inherit;
}
.sp-chip:hover { border-color: var(--app-brand); color: var(--app-text); }
.sp-chip--active {
    background: var(--app-brand);
    border-color: var(--app-brand);
    color: #fff;
    box-shadow: 0 2px 8px color-mix(in srgb, var(--app-brand) 35%, transparent);
}

/* Slider */
.sp-slider-row { display: flex; align-items: center; gap: 0.5rem; }
.sp-slider {
    flex: 1;
    accent-color: var(--app-brand);
    cursor: pointer;
}
.sp-slider-tick { font-size: 0.75rem; color: var(--app-text-mute); width: 1rem; text-align: center; }
.sp-slider-hint { font-size: 0.75rem; color: var(--app-text-mute); margin-top: -0.2rem; }

/* Field row */
.sp-field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; }
.sp-field { display: flex; flex-direction: column; gap: 0.25rem; }
.sp-field__label { font-size: 0.78rem; color: var(--app-text-mute); font-weight: 500; }

.sp-input {
    padding: 0.4rem 0.6rem;
    font-size: 0.85rem;
    font-family: inherit;
    background: var(--app-bg-elev);
    border: 1.5px solid var(--app-border);
    border-radius: 0.4rem;
    color: var(--app-text);
    outline: none;
    transition: border-color 120ms ease, box-shadow 120ms ease;
}
.sp-input:focus { border-color: var(--app-brand); box-shadow: 0 0 0 3px color-mix(in srgb, var(--app-brand) 18%, transparent); }
.sp-input::placeholder { color: var(--app-text-mute); opacity: 1; }

/* Colour swatches */
.sp-colors { display: flex; gap: 0.6rem; flex-wrap: wrap; }

.sp-color-swatch {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--app-bg-elev);
    border: 1.5px solid var(--app-border);
    border-radius: 0.5rem;
    padding: 0.35rem 0.6rem;
    min-width: 9rem;
    flex: 1;
    position: relative;
    transition: border-color 120ms ease;
}
.sp-color-swatch:hover { border-color: var(--app-brand); }

.sp-color-input {
    width: 2rem;
    height: 2rem;
    border-radius: 0.35rem;
    border: none;
    padding: 0;
    cursor: pointer;
    background: none;
    flex-shrink: 0;
}
.sp-color-input::-webkit-color-swatch-wrapper { padding: 0; }
.sp-color-input::-webkit-color-swatch { border: none; border-radius: 0.3rem; }

.sp-color-label { display: flex; align-items: center; gap: 0.4rem; min-width: 0; flex: 1; }
.sp-color-dot { width: 0.65rem; height: 0.65rem; border-radius: 50%; flex-shrink: 0; border: 1px solid rgba(0,0,0,0.1); }
.sp-color-label code { font-size: 0.75rem; overflow: hidden; text-overflow: ellipsis; }
.sp-colors-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
}

.sp-add-color-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    border: 1.5px dashed var(--app-border);
    background: transparent;
    color: var(--app-brand);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    white-space: nowrap;
}
.sp-add-color-btn:hover {
    background: color-mix(in srgb, var(--app-brand) 8%, transparent);
    border-color: var(--app-brand);
}

.sp-clear-btn {
    position: absolute;
    top: -0.4rem;
    right: -0.4rem;
    width: 1.1rem;
    height: 1.1rem;
    border-radius: 50%;
    background: var(--app-brand);
    color: #fff;
    border: 0;
    font-size: 0.7rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
}

.sp-toggle-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    margin-top: 0.25rem;
    user-select: none;
}
.sp-toggle-text { font-size: 0.85rem; font-weight: 500; color: var(--app-text); }
.sp-toggle-hint { font-size: 0.75rem; color: var(--app-text-mute); }

/* ── Preview panel ──────────────────────────────────────────── */
.sp-preview-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    width: 18rem;
}

.sp-preview-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--app-text-mute);
    align-self: flex-start;
}

.sp-preview-stage {
    width: 100%;
    min-height: 14rem;
    background: radial-gradient(ellipse at center, color-mix(in srgb, var(--app-brand) 5%, transparent) 0%, transparent 70%),
                var(--app-bg);
    border: 1.5px dashed var(--app-border);
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
}

.sp-preview-meta {
    display: flex;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--app-text-mute);
    flex-wrap: wrap;
    justify-content: center;
}

/* ── Overlay content box ────────────────────────────────────── */
.sp-overlay-content {
    background: var(--app-code-bg);
    border: 1px solid var(--app-border);
    border-radius: 0.5rem;
    padding: 1rem;
    min-height: 5.5rem;
    margin-bottom: 0;
}

/* ── Size showcase row ──────────────────────────────────────── */
.sp-size-row {
    display: flex;
    align-items: flex-end;
    gap: 2rem;
    flex-wrap: wrap;
    padding: 1.5rem 0 0.5rem;
}
.sp-size-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
}
.sp-size-label {
    font-size: 0.72rem;
    color: var(--app-text-mute);
    letter-spacing: 0.04em;
}

/* ── Presets gallery ────────────────────────────────────────── */
.spinner-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: 1rem;
    margin-top: 0.5rem;
}
.spinner-gallery__card {
    border: 1.5px solid var(--app-border);
    border-radius: 0.75rem;
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.18s, box-shadow 0.18s;
}
.spinner-gallery__card:hover {
    border-color: var(--app-brand);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--app-brand) 15%, transparent);
}
.spinner-gallery__preview {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 8rem;
    background: radial-gradient(ellipse at center,
        color-mix(in srgb, var(--app-brand) 5%, transparent) 0%,
        transparent 70%),
        var(--app-bg);
    border-bottom: 1px solid var(--app-border);
}
.spinner-gallery__info {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}
.spinner-gallery__name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--app-text);
}
.spinner-gallery__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
}
.sg-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 500;
    background: var(--app-code-bg);
    color: var(--app-text-mute);
    border: 1px solid var(--app-border);
}
.sg-tag--variant { background: color-mix(in srgb, var(--app-brand) 12%, transparent); color: var(--app-brand); border-color: color-mix(in srgb, var(--app-brand) 25%, transparent); }
.sg-tag--size    { background: color-mix(in srgb, #10b981 12%, transparent); color: #10b981; border-color: color-mix(in srgb, #10b981 25%, transparent); }
.sg-tag--colors  { background: color-mix(in srgb, #f59e0b 10%, transparent); color: #92400e; border-color: color-mix(in srgb, #f59e0b 25%, transparent); }
.sg-color-dot {
    display: inline-block;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    border: 1px solid rgba(0,0,0,0.12);
    flex-shrink: 0;
}
.spinner-gallery__code {
    position: relative;
}
.spinner-gallery__code pre {
    margin: 0;
    padding: 0.6rem 0.75rem;
    background: var(--app-code-bg);
    border: 1px solid var(--app-border);
    border-radius: 0.45rem;
    font-size: 0.7rem;
    line-height: 1.55;
    overflow-x: auto;
    white-space: pre;
    color: var(--app-text);
}
.sg-copy-btn {
    position: absolute;
    top: 0.35rem;
    right: 0.35rem;
    padding: 0.15rem 0.5rem;
    border-radius: 0.3rem;
    border: 1px solid var(--app-border);
    background: var(--app-surface);
    color: var(--app-text-mute);
    font-size: 0.68rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
}
.sg-copy-btn:hover { background: var(--app-brand); color: #fff; border-color: var(--app-brand); }
.sg-copy-btn--copied { background: #10b981; color: #fff; border-color: #10b981; }
</style>
