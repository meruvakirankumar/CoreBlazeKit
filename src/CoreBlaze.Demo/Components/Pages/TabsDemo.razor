@page "/layout/tabs"
@inject PersonRepository Repo

<PageTitle>Tabs · CoreBlaze</PageTitle>

<div class="page-header">
    <h1>Tabs</h1>
    <p class="text-muted">
        Sectioned navigation with a tab-header strip. Declare <code>&lt;Tab&gt;</code>
        children directly. Active tab is two-way bindable, supports icons, disabled states,
        and programmatic switching.
    </p>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="demo-section">
            <h3>Basic tabs</h3>
            <p class="demo-section__hint">First enabled tab is active by default. Billing is locked via <code>Disabled="true"</code>.</p>
            <Tabs>
                <ChildContent>
                    <Tab Title="Profile" Icon="👤">
                        <Stack Direction="StackDirection.Row" Gap="3" Align="StackAlign.Center">
                            <div class="avatar-placeholder">AA</div>
                            <div>
                                <div class="fw-600">Alice Anderson</div>
                                <div class="text-muted" style="font-size:.85rem">Engineering · Joined 2019</div>
                            </div>
                        </Stack>
                    </Tab>
                    <Tab Title="Settings" Icon="⚙">
                        <Stack Direction="StackDirection.Column" Gap="3">
                            <TextInput Label="Display name" Value="Alice Anderson" />
                            <Dropdown TItem="string" TValue="string"
                                      Items="@(new[] { "Light", "Dark", "System" })"
                                      ValueSelector="x => x"
                                      TextSelector="x => x"
                                      Label="Theme"
                                      Value="@("Light")" />
                        </Stack>
                    </Tab>
                    <Tab Title="Activity" Icon="📊">
                        <p class="text-muted mb-0">12 commits &nbsp;·&nbsp; 3 open PRs &nbsp;·&nbsp; 4 reviews this month.</p>
                    </Tab>
                    <Tab Title="Billing" Icon="💳" Disabled="true">
                        <p>Not available for this account type.</p>
                    </Tab>
                </ChildContent>
            </Tabs>
        </div>

        <div class="demo-section">
            <h3>Two-way bind — external control</h3>
            <p class="demo-section__hint">
                Use <code>@@bind-ActiveTitle</code> to drive the active tab from outside.
                Try the buttons below, then click a header tab directly.
            </p>
            <Stack Direction="StackDirection.Row" Gap="2" Wrap="true" CssClass="mb-3">
                @foreach (var t in new[] { "Overview", "Details", "History" })
                {
                    <button class="btn btn-sm @(_activeTab == t ? "btn-primary" : "btn-outline-secondary")"
                            @onclick="() => _activeTab = t">
                        @t
                    </button>
                }
            </Stack>
            <Tabs @bind-ActiveTitle="_activeTab">
                <ChildContent>
                    <Tab Title="Overview">
                        <p class="text-muted mb-0">Overview tab — switch externally or click the header.</p>
                    </Tab>
                    <Tab Title="Details">
                        <p class="text-muted mb-0">Details tab. <code>_activeTab</code> stays in sync.</p>
                    </Tab>
                    <Tab Title="History">
                        <p class="text-muted mb-0">History tab. Active: <strong>@_activeTab</strong></p>
                    </Tab>
                </ChildContent>
            </Tabs>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="demo-section">
            <h3>Usage</h3>
            <CodeSample Code="@_code" />
        </div>

        <div class="demo-section">
            <h3>API — Tabs</h3>
            <ul class="api-list">
                <li><code>@@bind-ActiveTitle</code> — two-way string</li>
                <li><code>OnTabChanged</code> — <code>EventCallback&lt;Tab&gt;</code></li>
                <li><code>SetActiveAsync(title)</code> — programmatic switch</li>
            </ul>
            <h3 class="mt-3">API — Tab</h3>
            <ul class="api-list">
                <li><code>Title</code> — header label (required)</li>
                <li><code>Icon</code> — string rendered before the title</li>
                <li><code>ChildContent</code> — panel content</li>
                <li><code>Disabled</code> — prevent selection</li>
            </ul>
        </div>
    </div>
</div>

<style>
    .avatar-placeholder {
        width: 2.5rem; height: 2.5rem; border-radius: 999px;
        background: linear-gradient(135deg, #6366f1, #22d3ee);
        color: #fff; font-weight: 700;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: .9rem; flex-shrink: 0;
    }
    .fw-600 { font-weight: 600; }
</style>
